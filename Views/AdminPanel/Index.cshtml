@model Blogger_website.Models.ViewModels.AdminDashboardViewModel

<div class="stats-grid">
    <div class="stat-card">
        <div class="stat-icon purple">
            <svg fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9a2 2 0 00-2-2h-2"/></svg>
        </div>
        <div>
            <div class="stat-value">@Model.TotalBlogs</div>
            <div class="stat-label">Total Blogs</div>
        </div>
    </div>
    <div class="stat-card">
        <div class="stat-icon green">
            <svg fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
        </div>
        <div>
            <div class="stat-value">@Model.PublishedBlogs</div>
            <div class="stat-label">Published</div>
        </div>
    </div>
    <div class="stat-card">
        <div class="stat-icon orange">
            <svg fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/></svg>
        </div>
        <div>
            <div class="stat-value">@Model.DraftBlogs</div>
            <div class="stat-label">Drafts</div>
        </div>
    </div>
    @if (Model.IsSuperAdmin)
    {
        <div class="stat-card">
            <div class="stat-icon blue">
                <svg fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
            </div>
            <div>
                <div class="stat-value">@Model.PendingAdmins</div>
                <div class="stat-label">Pending Admins</div>
            </div>
        </div>
    }
</div>

<div class="admin-card">
    <div class="admin-card-header">
        <h2>Recent Blogs</h2>
        <a asp-action="Create" class="btn-brand btn-sm">+ New Blog</a>
    </div>
    <div class="admin-card-body">
        @if (!Model.RecentBlogs.Any())
        {
            <div class="empty-state" style="border:none;margin:1rem;">
                <h3>No blogs yet</h3>
                <p>Create your first blog post!</p>
                <a asp-action="Create" class="btn-brand btn-sm" style="margin-top:0.75rem;">Create Blog</a>
            </div>
        }
        else
        {
            <div class="table-responsive">
                <table class="admin-table">
                    <thead>
                        <tr><th>Title</th><th>Status</th><th>Date</th><th></th></tr>
                    </thead>
                    <tbody>
                        @foreach (var blog in Model.RecentBlogs)
                        {
                            <tr>
                                <td><strong>@blog.Title</strong></td>
                                <td>
                                    @if (blog.IsPublished)
                                    { <span class="badge badge-success">Published</span> }
                                    else
                                    { <span class="badge badge-warning">Draft</span> }
                                </td>
                                <td>@blog.CreatedAt.ToString("dd MMM yyyy")</td>
                                <td>
                                    <div class="table-actions">
                                        <a asp-action="Edit" asp-route-id="@blog.Id" class="btn-ghost btn-sm">Edit</a>
                                        @if (blog.IsPublished)
                                        {
                                            <a asp-controller="Blog" asp-action="Details" asp-route-slug="@blog.Slug" target="_blank" class="btn-ghost btn-sm">View</a>
                                        }
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>

@if (Model.IsSuperAdmin && Model.PendingAdmins > 0)
{
    <div class="alert alert-warning" style="margin-top:1.25rem;">
        You have <strong>@Model.PendingAdmins</strong> admin registration(s) waiting for approval.
        <a asp-action="Pending" style="color:inherit;font-weight:700;margin-left:0.5rem;">Review now →</a>
    </div>
}
