@{
    ViewData["Title"] = "Privacy Policy";
}

<section class="section" style="padding-top:2.5rem;max-width:760px;">
    <h1 style="font-size:2rem;font-weight:800;margin-bottom:1rem;">Privacy Policy</h1>
    <p style="color:var(--text-muted);line-height:1.8;">
        BlogHub respects your privacy. We collect only the information necessary to provide our blogging platform —
        such as your name, email, and comments you post. Admin accounts are managed securely through our authentication system.
        We do not sell your personal data to third parties.
    </p>
</section>
