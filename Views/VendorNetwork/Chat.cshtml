@model Blogger_website.Models.ViewModels.VendorChatViewModel

<div class="admin-card vendor-chat-room">
    <div class="admin-card-header">
        <div>
            <a asp-action="Chats" class="btn-ghost btn-sm" style="margin-bottom:0.35rem;">← All Chats</a>
            <h2 style="margin:0;">Chat with @Model.OtherUserName</h2>
        </div>
    </div>
    <div class="vendor-chat-messages" id="chatMessages"
         data-thread-id="@Model.Thread.Id"
         data-last-id="@(Model.Messages.LastOrDefault()?.Id ?? 0)"
         data-current-user="@Model.CurrentUserName"
         data-current-user-id="@Model.CurrentUserId">
        @foreach (var msg in Model.Messages)
        {
            @await Html.PartialAsync("_ChatMessage", msg)
        }
    </div>
    <div class="vendor-chat-compose">
        <div id="chatReplyBar" class="chat-reply-bar hidden">
            <div class="chat-reply-bar-inner">
                <div>
                    <strong id="chatReplyToName"></strong>
                    <p id="chatReplyToText"></p>
                </div>
                <button type="button" id="chatReplyCancel" class="icon-btn" title="Cancel reply">×</button>
            </div>
        </div>
        <form asp-action="SendMessage" method="post" id="chatForm">
            @Html.AntiForgeryToken()
            <input type="hidden" name="threadId" value="@Model.Thread.Id" />
            <textarea name="content" id="chatInput" class="form-control" rows="2" required placeholder="Type a message... (Enter to send)"></textarea>
            <button type="submit" class="btn-brand">Send</button>
        </form>
    </div>
</div>

<div id="chatContextMenu" class="chat-context-menu hidden" role="menu"></div>

<div id="chatDeleteModal" class="chat-modal hidden">
    <div class="chat-modal-backdrop" data-close="delete"></div>
    <div class="chat-modal-sheet">
        <h4>Delete message?</h4>
        <button type="button" class="chat-modal-btn chat-modal-danger" data-delete="all" id="chatDeleteAllBtn">Delete for everyone</button>
        <button type="button" class="chat-modal-btn chat-modal-danger" data-delete="me">Delete for me</button>
        <button type="button" class="chat-modal-btn chat-modal-cancel" data-delete="cancel">Cancel</button>
    </div>
</div>

@section Scripts {
    <script src="~/js/vendor-chat.js" asp-append-version="true"></script>
}
