@using Blogger_website.Models.Constants
@using Microsoft.AspNetCore.Identity
@using Blogger_website.Areas.Identity.Data
@inject UserManager<ApplicationUser> UserManager
@{
    var isSuperAdmin = User.IsInRole(AppRoles.SuperAdmin);
    var currentUser = await UserManager.GetUserAsync(User);
    var initials = currentUser?.FullName?.Length > 0
        ? currentUser.FullName[..1].ToUpper()
        : (currentUser?.Email?[..1].ToUpper() ?? "A");
    var controller = ViewContext.RouteData.Values["controller"]?.ToString();
    var action = ViewContext.RouteData.Values["action"]?.ToString();
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Admin | BlogHub</title>
    <link rel="stylesheet" href="~/css/app.css" asp-append-version="true" />
</head>
<body class="admin-body">
    <div class="sidebar-overlay" id="sidebarOverlay"></div>
    <div class="admin-shell">
        <aside class="admin-sidebar" id="adminSidebar">
            <div class="sidebar-brand">Blog<span>Hub</span> Admin</div>
            <nav class="sidebar-nav">
                <div class="sidebar-section">Main</div>
                <a class="sidebar-link @(controller=="AdminPanel" && action=="Index" ? "active":"")" asp-controller="AdminPanel" asp-action="Index">
                    <svg fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-4 0a1 1 0 01-1-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 01-1 1"/></svg>
                    Dashboard
                </a>
                <a class="sidebar-link @(action=="Blogs"||action=="Create"||action=="Edit" ? "active":"")" asp-controller="AdminPanel" asp-action="Blogs">
                    <svg fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9a2 2 0 00-2-2h-2"/></svg>
                    My Blogs
                </a>
                <a class="sidebar-link @(action=="Create" ? "active":"")" asp-controller="AdminPanel" asp-action="Create">
                    <svg fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M12 4v16m8-8H4"/></svg>
                    New Blog
                </a>
                <a class="sidebar-link @(action=="Categories" ? "active":"")" asp-controller="AdminPanel" asp-action="Categories">
                    <svg fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M7 7h.01M7 3h5c.512 0 1.024.195 1.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A2 2 0 013 12V7a4 4 0 014-4z"/></svg>
                    Categories
                </a>
                <a class="sidebar-link @(action=="Comments" ? "active":"")" asp-controller="AdminPanel" asp-action="Comments">
                    <svg fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/></svg>
                    Comments
                </a>
                <a class="sidebar-link @(controller=="VendorNetwork" && action=="Vendors" ? "active":"")" asp-controller="VendorNetwork" asp-action="Vendors">
                    <svg fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
                    Vendor Network
                </a>
                <a class="sidebar-link @(controller=="VendorNetwork" && (action=="Chats" || action=="Chat") ? "active":"")" asp-controller="VendorNetwork" asp-action="Chats">
                    <svg fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M8 10h.01M12 10h.01M16 10h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/></svg>
                    Vendor Chat
                </a>

                @if (isSuperAdmin)
                {
                    <div class="sidebar-section">Super Admin</div>
                    <a class="sidebar-link @(action=="Pending" ? "active":"")" asp-controller="AdminPanel" asp-action="Pending">
                        <svg fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                        Pending Admins
                    </a>
                    <a class="sidebar-link @(action=="Bloggers" ? "active":"")" asp-controller="AdminPanel" asp-action="Bloggers">
                        <svg fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
                        All Bloggers
                    </a>
                    <a class="sidebar-link @(action=="Labels" ? "active":"")" asp-controller="AdminPanel" asp-action="Labels">
                        <svg fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M7 7h.01M7 3h5c.512 0 1.024.195 1.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A2 2 0 013 12V7a4 4 0 014-4z"/></svg>
                        Labels / Tags
                    </a>
                }
            </nav>
            <div class="sidebar-footer">
                <a class="sidebar-link" asp-area="Identity" asp-page="/Account/Manage/Index">
                    <svg fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/></svg>
                    Profile
                </a>
                <form asp-area="Identity" asp-page="/Account/Logout" asp-route-returnUrl="@Url.Action("Index", "Home")" method="post" class="sidebar-logout-form">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="sidebar-link sidebar-logout-btn">
                        <svg fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"/></svg>
                        Logout
                    </button>
                </form>
                <a class="sidebar-link" asp-controller="Blog" asp-action="Index" target="_blank">
                    <svg fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/></svg>
                    View Site
                </a>
            </div>
        </aside>

        <div class="admin-main">
            <header class="admin-topbar">
                <div class="topbar-left">
                    <button class="sidebar-toggle" id="sidebarToggle" aria-label="Toggle menu">
                        <svg width="24" height="24" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M4 6h16M4 12h16M4 18h16"/></svg>
                    </button>
                    <h1 class="topbar-title">@ViewData["Title"]</h1>
                </div>
                <div class="topbar-user-menu" id="userMenu">
                    <button class="user-menu-trigger" id="userMenuToggle" type="button" aria-haspopup="true" aria-expanded="false">
                        <span class="user-menu-name">@(currentUser?.FullName ?? currentUser?.Email)</span>
                        <div class="user-avatar">@initials</div>
                        <svg class="user-menu-chevron" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M6 9l6 6 6-6"/></svg>
                    </button>
                    <div class="user-menu-dropdown" id="userMenuDropdown">
                        <div class="user-menu-header">
                            <div class="user-avatar user-avatar-lg">@initials</div>
                            <div>
                                <strong>@(currentUser?.FullName ?? "Admin")</strong>
                                <span>@currentUser?.Email</span>
                                @if (isSuperAdmin)
                                {
                                    <span class="badge badge-primary user-role-badge">Super Admin</span>
                                }
                            </div>
                        </div>
                        <a class="user-menu-item" asp-area="Identity" asp-page="/Account/Manage/Index">
                            <svg fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/></svg>
                            Profile
                        </a>
                        <a class="user-menu-item" asp-area="Identity" asp-page="/Account/Manage/ChangePassword">
                            <svg fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M15 7a2 2 0 012 2m4 0a6 6 0 01-7.743 5.743L11 17H9v2H7v2H4a1 1 0 01-1-1v-2.586a1 1 0 01.293-.707l5.964-5.964A6 6 0 1121 9z"/></svg>
                            Change Password
                        </a>
                        <div class="user-menu-divider"></div>
                        <form asp-area="Identity" asp-page="/Account/Logout" asp-route-returnUrl="@Url.Action("Index", "Home")" method="post" class="user-menu-logout">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="user-menu-item user-menu-logout-btn">
                                <svg fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"/></svg>
                                Logout
                            </button>
                        </form>
                    </div>
                </div>
            </header>
            <div class="admin-content">
                @if (TempData["Success"] != null)
                {
                    <div class="alert alert-success" data-auto-dismiss>@TempData["Success"]</div>
                }
                @if (TempData["Error"] != null)
                {
                    <div class="alert alert-danger" data-auto-dismiss>@TempData["Error"]</div>
                }
                @RenderBody()
            </div>
        </div>
    </div>
    <script src="~/js/app.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
