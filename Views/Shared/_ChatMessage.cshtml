@model Blogger_website.Models.Entities.VendorChatMessage

@{
    var displayName = string.IsNullOrWhiteSpace(Model.SenderName) ? "Vendor" : Model.SenderName;
    var deleted = Model.DeletedForEveryone;
    var deletedText = Model.IsMine ? "You deleted this message" : "This message was deleted";
    var hasReply = Model.ReplyToMessageId.HasValue;
    var replyName = Model.IsMine && Model.ReplyToSenderName == displayName ? "You" : (Model.ReplyToSenderName ?? "Vendor");
    var replyText = Model.ReplyToDeleted ? "This message was deleted" : (Model.ReplyToContent ?? "");
}

<div class="vendor-chat-row @(Model.IsMine ? "mine" : "theirs")" data-row-id="@Model.Id">
    <div class="vendor-chat-bubble chat-bubble-selectable"
         data-id="@Model.Id"
         data-sender-id="@Model.SenderUserId"
         data-mine="@(Model.IsMine ? "true" : "false")"
         data-sender="@displayName"
         data-content="@System.Net.WebUtility.HtmlEncode(deleted ? "" : Model.Content)"
         data-deleted="@(deleted ? "true" : "false")">
        <div class="vendor-chat-meta">
            <strong class="chat-sender-name">@displayName</strong>
            <span>· @Model.CreatedAt.ToString("dd MMM HH:mm")</span>
            @if (Model.EditedAt.HasValue && !deleted)
            {
                <span class="chat-edited-tag">edited</span>
            }
        </div>
        @if (hasReply && !deleted)
        {
            <div class="chat-quote-block">
                <strong>@replyName</strong>
                <p>@(string.IsNullOrWhiteSpace(replyText) ? "This message was deleted" : replyText)</p>
            </div>
        }
        <div class="vendor-chat-text @(deleted ? "chat-deleted-text" : "")">
            @(deleted ? deletedText : Model.Content)
        </div>
    </div>
</div>
