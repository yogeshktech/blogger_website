@model (int BlogId, string Slug, string Title, int LikeCount, bool IsLiked, string ShareUrl, bool Compact)

@{
    var (blogId, slug, title, likeCount, isLiked, shareUrl, compact) = Model;
    var encodedUrl = Uri.EscapeDataString(shareUrl);
    var encodedTitle = Uri.EscapeDataString(title);
}

<div class="blog-engage @(compact ? "blog-engage-compact" : "")" data-blog-id="@blogId" data-share-url="@shareUrl" data-share-title="@title">
    <button type="button"
            class="blog-like-btn @(isLiked ? "liked" : "")"
            data-liked="@(isLiked ? "true" : "false")"
            aria-pressed="@(isLiked ? "true" : "false")">
        <svg width="18" height="18" fill="@(isLiked ? "currentColor" : "none")" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"/></svg>
        <span class="blog-like-count">@likeCount</span>
        @if (!compact) { <span class="blog-like-label">@(isLiked ? "Liked" : "Like")</span> }
    </button>

    <div class="blog-share-group">
        @if (!compact) { <span class="blog-share-label">Share</span> }
        <button type="button" class="blog-share-btn" data-share="copy" title="Copy link">
            <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M8 5H6a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2v-1M8 5a2 2 0 002 2h2a2 2 0 002-2M8 5a2 2 0 012-2h2a2 2 0 012 2m0 0h2a2 2 0 012 2v3m2 4H10m0 0l3-3m-3 3l3 3"/></svg>
        </button>
        <a class="blog-share-btn" href="https://wa.me/?text=@encodedTitle%20@encodedUrl" target="_blank" rel="noopener" title="WhatsApp">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/><path d="M12 0C5.373 0 0 5.373 0 12c0 2.625.846 5.059 2.284 7.034L.789 23.492a.5.5 0 00.611.611l4.458-1.495A11.953 11.953 0 0012 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 22c-2.34 0-4.516-.676-6.378-1.84l-.455-.272-2.647.887.886-2.58-.296-.47A9.956 9.956 0 012 12C2 6.477 6.477 2 12 2s10 4.477 10 10-4.477 10-10 10z"/></svg>
        </a>
        <a class="blog-share-btn" href="https://www.facebook.com/sharer/sharer.php?u=@encodedUrl" target="_blank" rel="noopener" title="Facebook">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M24 12.073C24 5.405 18.627 0 12 0S0 5.405 0 12.073C0 18.1 4.388 23.094 10.125 24v-8.437H7.078v-3.49h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.49h-2.796V24C19.612 23.094 24 18.1 24 12.073z"/></svg>
        </a>
        <a class="blog-share-btn" href="https://twitter.com/intent/tweet?url=@encodedUrl&text=@encodedTitle" target="_blank" rel="noopener" title="X / Twitter">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
        </a>
    </div>
</div>
